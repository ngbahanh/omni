{
  "name": "omni",
  "version": "1.0.0",
  "description": "An extensible multi-tool CLI",
  "type": "module",
  "packageManager": "yarn@4.5.2",
  "bin": "./src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "logs:clear": "node -e \"import('fs').then(fs=>{fs.writeFileSync('.agents/logs/omni.log','');fs.writeFileSync('.agents/logs/errors.log','');})\""
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "inquirer": "^13.3.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
